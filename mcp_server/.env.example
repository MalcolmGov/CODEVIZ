# Base URL of the running CodeViz Flask backend
CODEVIZ_BASE_URL=http://localhost:8000

# Optional GitHub token forwarded as `Authorization: Bearer <token>`.
# Used when creating sessions for private repos and listing GitHub repos.
CODEVIZ_TOKEN=

# Per-request timeout in seconds (scans can be slow; default 120)
CODEVIZ_TIMEOUT=120

# Directory where generated PDF/HTML reports are written
CODEVIZ_REPORT_DIR=./codeviz-reports
