# Flask Configuration
SECRET_KEY=dev-secret-key-change-in-production
FLASK_APP=main.py
FLASK_ENV=development

# GitHub OAuth Integration
# Create an OAuth app on GitHub (Settings -> Developer Settings -> OAuth Apps)
# Redirect URI: http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# Frontend Redirect Url
FRONTEND_URL=http://localhost:5173

# Database & Redis Settings
DATABASE_URL=postgresql://codeviz:codeviz@localhost:5432/codeviz
REDIS_URL=redis://localhost:6379/0

# Ollama / LLM Settings (powers natural-language code Q&A)
OLLAMA_BASE_URL=http://localhost:11434
# Pull the model into the SAME server this URL points to:
#   curl http://localhost:11434/api/pull -d '{"name":"qwen2.5-coder:3b"}'
# 3b is a good fit for ~16GB RAM; use 7b for higher quality if you have headroom.
OLLAMA_MODEL=qwen2.5-coder:3b
# Per-request timeout (seconds). Raise for larger models / cold starts.
OLLAMA_TIMEOUT=180
# Keep the model resident in memory between questions (fewer cold reloads).
OLLAMA_KEEP_ALIVE=10m
# Cap generated tokens to bound latency on slower hardware.
OLLAMA_NUM_PREDICT=768
# Set to 0/false to disable LLM-backed chat (forces keyword fallback)
ENABLE_LLM_CHAT=1
